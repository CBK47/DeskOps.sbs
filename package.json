{
  "name": "deskops",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "overrides": {
    "postcss": "8.5.19"
  },
  "scripts": {
    "dev": "npm --workspace @deskops/frontend run dev",
    "build": "npm --workspace @deskops/frontend run build",
    "start": "npm --workspace @deskops/frontend run start",
    "lint": "npm --workspace @deskops/frontend run lint",
    "typecheck": "npm --workspace @deskops/frontend run typecheck",
    "test": "npm --workspace @deskops/frontend run test",
    "test:watch": "npm --workspace @deskops/frontend run test:watch",
    "test:e2e": "npm --workspace @deskops/frontend run test:e2e",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build && npm run worker:build && npm run test:e2e",
    "gen:types": "npm --workspace @deskops/frontend run gen:types",
    "worker:build": "npm --workspace @deskops/frontend run worker:build",
    "worker:preview": "npm --workspace @deskops/frontend run worker:preview",
    "worker:deploy": "npm --workspace @deskops/frontend run worker:deploy",
    "seed:personal": "if test -f personal/streams.local.sql; then supabase db query --linked --file personal/streams.local.sql --workdir . --agent=no; else echo 'No personal/streams.local.sql found; skipping.'; fi"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "esbuild": "^0.28.1",
    "hono": "^4.12.30",
    "js-yaml": "^4.3.0",
    "qs": "^6.15.3",
    "vite": "^8.0.16"
  }
}
