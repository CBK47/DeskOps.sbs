# Public values supplied by your Supabase project settings.
# Do not put a service-role key in this file or expose one to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Keep these server-only. The exact model is configured at deployment time.
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=gpt-5.6
