# Public values supplied by your Supabase project settings.
# Do not put a service-role key in this file or expose one to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Keep these server-only. The exact model is configured at deployment time.
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=gpt-5.6

# Paid anonymous drafting is off by default. It also requires the bounded
# public-demo gate and the two OpenAI values above.
DEMO_AGENT_LIVE_AI=false

# Personal-mode extra. Both flags must be true to expose invoice drafting.
ENABLE_INVOICES=false
NEXT_PUBLIC_ENABLE_INVOICES=false
